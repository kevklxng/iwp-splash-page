NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_WRITE_TOKEN=

# Splash mode: "true" = coming-soon home only; all other pages redirect to / (see middleware.ts).
# Set SPLASH_MODE and NEXT_PUBLIC_SPLASH_MODE on Vercel before deploy. Set to "false" when launching the full site.
SPLASH_MODE=true
NEXT_PUBLIC_SPLASH_MODE=true
NEXT_PUBLIC_FACEBOOK_URL=https://www.facebook.com/Templetoncustomhomes/

# Google Sheet via Apps Script (POST { secret, row }) — see docs/splash-apps-script.md
GOOGLE_SHEETS_WEBHOOK_URL=
GOOGLE_SHEETS_WEBHOOK_SECRET=

RESEND_API_KEY=
CONTACT_TO_EMAIL=
CONTACT_FROM_EMAIL=no-reply@iwp.fund

NEXT_PUBLIC_GA4_MEASUREMENT_ID=

# Canonical site URL (no trailing slash). Used for metadata, Open Graph, sitemap, and robots.txt.
# Production: https://www.iwp.fund
NEXT_PUBLIC_SITE_URL=https://www.iwp.fund

# Server-only base URL for local scripts (e.g. pull:submissions). Optional on Vercel.
SITE_URL=

# Vercel Postgres (auto-populated when you link a Postgres database in the Vercel dashboard)
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=

# Admin API (Bearer token for GET /api/admin/submissions and npm run pull:submissions)
ADMIN_API_SECRET=
